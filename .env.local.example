# ================================================
# ClipContest — Environment Variables
# Rename this file to .env.local and fill in values
# NEVER commit .env.local to Git!
# ================================================

# --- Supabase ---
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Keep secret — server only!

# --- Resend (Email) ---
# Get from: https://resend.com → API Keys
# Uncomment in src/app/api/waitlist/route.ts to activate emails
RESEND_API_KEY=re_your_api_key

# --- Analytics (optional) ---
# Plausible
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=clipcontest.io

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
